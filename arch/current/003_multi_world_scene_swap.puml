@startuml current_003_multi_world_scene_swap
title UC Life Sim — multi-world ECS + scene swap

skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultFontName "Inter, sans-serif"
skinparam linetype ortho
left to right direction

' ── data + ecs ────────────────────────────────────────────────
package "data/scenes.json5" as P_SCN #f3f6fa {
  [scenes[] + initialSceneId] as SCENES
}

package "ecs/world.ts" as P_W #fff8ec {
  [worlds : Map<SceneId, World>] as WMAP
  [activeId : SceneId]           as ACTIVE
  [world (Proxy)]                as WPROXY
  [getWorld(id)]                 as GW
}

' ── runtime: scene store + boot ───────────────────────────────
package "sim/scene.ts" as P_SC #fff3e6 {
  [useScene\nactiveId, swapNonce, setActive] as USESC
  [migratePlayerToScene\nboardShip / disembarkShip] as MIG
}

package "boot — main.tsx :: ScopedRoot" as P_BOOT #ffffff {
  [WorldProvider world={getWorld(activeId)}] as WP
  [<App key={`${activeId}-${swapNonce}`}/>]   as APPK
}

' ── consumers ─────────────────────────────────────────────────
[Game.tsx\nworld.query()] as RG
[HUD\nuseQuery / useTrait] as HUD

' ── wiring ────────────────────────────────────────────────────
SCENES  --> WMAP   : 1 koota.World per id\n(createWorld() at module init)
WPROXY  --> ACTIVE
WPROXY  --> WMAP   : forwards to worlds.get(activeId)
GW      --> WMAP

USESC   --> ACTIVE : setActiveSceneId(id)
USESC   --> APPK   : ++swapNonce → remount
MIG     --> USESC

WP      --> GW
APPK    --> USESC
RG      --> WPROXY
HUD     --> WP

note right of WPROXY
  Methods are *bound* to the real World
  before being returned, so koota's
  private fields (#id, #isInitialized)
  resolve. A naked Proxy without bind
  breaks reset() / id getters.
end note

note right of APPK
  Composite `${activeId}-${swapNonce}`
  forces full App remount on every
  setActive — even same-scene swaps.
  Reasons:
  (a) WorldProvider must bind to the
      *actual* World, not the proxy;
  (b) world.reset() (in loadGame) clears
      koota's queriesHashMap, orphaning
      live useQuery hooks. Remount gives
      fresh hooks that re-scan.
end note

note right of MIG
  Cross-scene = destroy + respawn.
  Entity ids are world-stamped.
  Carries portable traits over.
  Drops Job / Home / PendingEviction
  (point at origin-scene entities).
end note

note bottom of WMAP
  Worlds in play at HEAD:
   - vonBraun           (default city)
   - playerShipInterior (FTL-shape ship)
   - spaceCampaign      (continuous physics)
  All eagerly constructed at module init.
end note

@enduml

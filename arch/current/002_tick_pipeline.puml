@startuml current_002_tick_pipeline
title UC Life Sim — per-frame tick pipeline (sim/loop.ts :: frame())

skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam defaultFontName "Inter, sans-serif"

actor "browser RAF" as raf
participant "sim/loop\nframe(now)" as L
participant "combatSystem" as COMBAT
participant "spaceSimSystem\n(spaceCampaign world)" as SPACE
participant "real-time triple\nmovement → npc → interaction" as REAL
participant "per-tick chain\n(14 systems, see note)" as TICK
participant "sim/events\n(pub/sub seam)" as EV
participant "boot/autosaveBinding\n(throttle + in-flight guard)" as SV
participant "ui (clock + toasts)" as UI

raf -> L : requestAnimationFrame

alt clock.mode === 'combat'
  L -> COMBAT : combatSystem(world, dt)
end

L -> SPACE : spaceSimSystem(dt/1000)
note right
  Always runs, regardless of active
  scene. Keeps off-helm autopilot
  integrating while the player walks
  around the ship interior.
end note

alt effectiveSpeed > 0
  L -> REAL : every frame
  loop while tickAccum >= 1\n(capped at MAX_TICKS_PER_FRAME = 200)
    L -> TICK : run chain in fixed order
  end
  alt day rollover
    L -> EV : emitSim('day:rollover')
    EV -> SV : autosaveBinding subscriber\n→ saveGame('auto')
  end
  L -> UI : evaluate hyperspeed gate;\nsetMode('committed' | 'normal')
  alt entering hyperspeed
    L -> EV : emitSim('hyperspeed:start')
    EV -> SV : autosaveBinding subscriber\n→ saveGame('auto')
  end
  alt leaving hyperspeed in danger
    L -> UI : showToast('快进暂停 · …') with\n'强制快进' action
  end
end

L -> raf : requestAnimationFrame(frame)

note over TICK
  Per-tick order (matters):
   1. clock.advance
   2. supplyDrain
   3. vitals
   4. action
   5. rent
   6. work
   7. stress              (after vitals — saturation seeing fresh values)
   8. releaseStaleBarSeats
   9. releaseStaleRoughSpots
  10. attributes
  11. population
  12. relations
  13. ambitions
  14. activeZone
end note

note over L, SV
  Autosave is decoupled via sim/events.ts.
  loop emits 'day:rollover' /
  'hyperspeed:start'; src/boot/
  autosaveBinding.ts subscribes and calls
  save/saveGame('auto') with throttle +
  in-flight guard. sim/loop no longer
  imports from save/.
end note

@enduml

// zh-CN copy for the branching NPC dialogue runner.
// Strings live here so writers can iterate without touching TS.
//
// Greeting / smallTalk / farewell tables are matched by job-title
// substring (see src/ui/dialogue/branches/smallTalk.ts).
{
  // Timings used by the runner / individual branches.
  timings: {
    // Delay between clicking 再见 and the NPCDialog closing — gives the
    // farewell line and audio time to register.
    farewellCloseMs: 800,
  },
  greetings: {
    default: '"你好。"',
    unemployed: '"嗯。"',
    cashier: '"欢迎光临。"',
    hr: '"你好，请问要应聘吗？"',
    realtor: '"您好，租房还是买房？"',
    manager: '"你好。"',
    bartender: '"想喝点什么？"',
    doctor: '"哪里不舒服？"',
    pharmacist: '"需要什么药？"',
    aeEngineer: '"你好。我是Anaheim的技术员。"',
    worker: '"嘿，朋友。"',
  },
  smallTalk: {
    default: '"嗯。"',
    unemployed: '"我也只是混口饭吃。日子能过就行。"',
    cashier: '"今天店里挺安静。这附近不太热闹。"',
    hr: '"工厂在招几个岗位，门槛不高。"',
    realtor: '"最近房源紧俏，看中了赶紧定。"',
    manager: '"工厂里事情多，闲不下来。"',
    bartender: '"夜班嘛，常客都是工人和零工。"',
    doctor: '"最近来咳嗽和肠胃的多。"',

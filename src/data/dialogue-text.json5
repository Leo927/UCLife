    default: '"再见。"',
    cashier: '"再来。"',
    hr: '"再考虑考虑。"',
    realtor: '"看好房源记得回来签约。"',
    manager: '"有事再来。"',
    bartender: '"走好，回头再来一杯。"',
    worker: '"走好。"',

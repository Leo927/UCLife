// Per-NPC appearance overrides for the FC pregmod portrait renderer.
// Keys are the NPC's `Character.name` (Chinese-language). Each entry overrides
// any subset of the random Appearance generated by `data/appearanceGen` from
// the name-hash seed. Fields you omit keep their generated value.
//
// FC color name conventions (see `extractColor` in helpers/artHelpers.js):
//   Hair/eye: 'black', 'brown', 'auburn', 'chestnut', 'blonde', 'platinum
//     blonde', 'red', 'ginger', 'silver', 'grey', 'amber', 'hazel', 'green',
//     'blue', 'sapphire', 'amethyst', 'neon pink', or any HTML color name /
//     hex code.
//   Skin: 'fair', 'light', 'pale', 'tanned', 'dark', 'olive', 'brown', etc.
//
// hStyle convention: 'neat', 'messy bun', 'tails', 'shoulder-length',
// 'short', 'pixie', 'crew cut', 'shaved', etc.
//
// Setting `gender` here forces the appearance generator to produce body
// proportions for that gender before the override is applied; without it,
// the seed picks 50/50 and your hand-tuned hair on top of a wrong-gender
// body looks off.
//
// Adding a new NPC: just add a new key matching their Character.name.

{
  // === Anaheim Electronics board ===
  // Three executives the player meets through the AE reception desk. Distinct
  // looks make the AE crowd feel like specific people instead of clones.

  "米利亚·卡里": {
    // AE chairwoman. Older, dignified. Light skin, silver hair worn long.
    gender: "female",
    skin: "fair",
    hStyle: "neat",
    hColor: "silver",
    hLength: 50,
    pubicHColor: "silver",
    underArmHColor: "silver",
    eyeIris: "blue",
    weight: 5,
    muscles: 0,
    makeup: 2,
    physicalAge: 52,
  },

  "乔治·米格尔": {
    // AE board member. Mediterranean look — tan skin, chestnut hair, hazel
    // eyes. Renderer doesn't model facial hair directly.
    gender: "male",
    skin: "tanned",
    hStyle: "short",
    hColor: "chestnut",
    hLength: 15,
    pubicHColor: "chestnut",
    underArmHColor: "chestnut",
    eyeIris: "hazel",
    weight: 10,
    muscles: 25,
    makeup: 0,
    physicalAge: 41,
  },

  "安娜海姆·世津": {
    // AE vice chair. Japanese-coded; black hair shoulder-length, fair skin,
    // brown eyes. Conservative makeup.
    gender: "female",
    skin: "light",
    hStyle: "shoulder-length",
    hColor: "black",
    hLength: 35,
    pubicHColor: "black",
    underArmHColor: "black",
    eyeIris: "brown",
    weight: -5,
    muscles: 5,
    makeup: 1,
    physicalAge: 45,
  },

  // === Player character ===

  "新人": {
    // The player. Unremarkable on purpose — a fresh arrival with no
    // distinguishing features. Players will project onto this.
    gender: "female",
    skin: "light",
    hStyle: "neat",
    hColor: "brown",
    hLength: 20,
    pubicHColor: "brown",
    underArmHColor: "brown",
    eyeIris: "brown",
    weight: 0,
    muscles: 0,
    makeup: 0,
    physicalAge: 22,
  },
}

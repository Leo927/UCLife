{
  // ── OPEN FLOOR: commercial ──────────────────────────────────────────────

  bar: {
    labelZh: '酒吧',
    size: { minW: 5, maxW: 8, minH: 3, maxH: 5 },
    layout: {
      algorithm: 'open_floor',
      items: [
        { type: 'workstation', specId: 'bartender', role: 'supervisor', labelZh: '吧台' },
        { type: 'bar_seat', role: 'customer_row', count: 5 },
        { type: 'queue_point', role: 'queue' },
      ],
    },
  },

  // City HR clerk's window. Per the worker-not-workstation rule the
  // window itself is scenery; the talk-verb on city_hr_clerk surfaces
  // the public job board (HRConversation in NPCDialog).
  // stateLocked: civic infrastructure — city runs the public job board
  // forever; the realtor never lists it, no faction (or player) can buy.
  hrOffice: {
    labelZh: '市民人事局',
    stateLocked: true,
    size: { minW: 5, maxW: 8, minH: 3, maxH: 5 },
    layout: {
      algorithm: 'open_floor',
      items: [
        { type: 'workstation', specId: 'city_hr_clerk', role: 'supervisor', noInteractable: true, labelZh: '招聘窗口' },
      ],
    },
  },

  // Realtor's desk — scenery. The talk-verb on the realtor NPC drives
  // listing browse + close-the-sale (RealtorConversation in NPCDialog).
  realtor: {
    labelZh: '房产中介',
    size: { minW: 5, maxW: 8, minH: 3, maxH: 5 },
    layout: {
      algorithm: 'open_floor',
      items: [
        { type: 'workstation', specId: 'realtor', role: 'supervisor', noInteractable: true, labelZh: '中介台' },
      ],
    },
  },

  // Phase 5.5.4 recruiter office. Player-ownable HR office; the recruiter
  // workstation runs the procgen-applicant pipeline (recruitmentSystem
  // generates applicants daily; they walk into the lobby, idle, and either
  // get accepted via auto-filter / manual review, or expire and despawn).
  // The desk itself is scenery — talk-verb on the seated recruiter NPC
  // drives criteria-as-conversation + the applicant lobby
  // (RecruiterConversation in NPCDialog).
  recruitOffice: {
    labelZh: '招聘代理处',
    size: { minW: 6, maxW: 8, minH: 4, maxH: 5 },
    hasManageCell: true,
    layout: {
      algorithm: 'open_floor',
      items: [
        { type: 'workstation', specId: 'recruiter', role: 'supervisor', noInteractable: true, labelZh: '招聘办公桌' },
      ],
    },
  },

  // Phase 5.5.6 research lab. Player-ownable factionMisc facility; the
  // researcher workstation runs the per-day research progress pipeline
  // (researchSystem accumulates progress against the head of
  // FactionResearch.queue and rolls overflow into the next entry). The
  // desk itself is scenery — talk-verb on the seated researcher NPC
  // drives the consultative branch + planner panel
  // (ResearcherConversation in NPCDialog).
  researchLab: {
    labelZh: '研究室',
    size: { minW: 6, maxW: 8, minH: 4, maxH: 5 },
    hasManageCell: true,
    layout: {
      algorithm: 'open_floor',
      items: [
        { type: 'workstation', specId: 'researcher', role: 'supervisor', noInteractable: true, labelZh: '研究台' },
      ],
    },
  },

  // Phase 5.5.3 faction office. Single supervisor desk for the secretary —
  // a hired NPC the player installs via the per-facility manage cell
  // (Interactable kind 'manage', spawned at building center when
  // `hasManageCell: true`) once they own the office. The desk is
  // scenery; the secretary's consultative verbs render inline in
  // NPCDialog (SecretaryConversation) when the player chats her up.
  factionOffice: {
    labelZh: '势力办公室',
    size: { minW: 5, maxW: 8, minH: 3, maxH: 5 },
    hasManageCell: true,
    layout: {
      algorithm: 'open_floor',
      items: [
        { type: 'workstation', specId: 'secretary', role: 'supervisor', noInteractable: true, labelZh: '秘书办公桌' },
      ],
    },
  },

  // Civilian clinic. Doctor at the supervisor desk runs the diagnose +
  // treatment-tier flow inline in NPCDialog (ClinicConversation). The
  // desk is scenery — the talk-verb on the doctor is the surface.
  clinic: {
    labelZh: '诊所',
    size: { minW: 5, maxW: 8, minH: 3, maxH: 5 },
    layout: {
      algorithm: 'open_floor',
      items: [
        { type: 'workstation', specId: 'civilian_doctor', role: 'supervisor', noInteractable: true, labelZh: '诊台' },
      ],
    },
  },

  // Civilian pharmacy. Pharmacist at the supervisor desk sells
  // pharmacy-tier (tier 1) treatment for already-diagnosed conditions
  // through PharmacyConversation. No diagnosis here — players who want
  // a diagnosis must visit the clinic first. Counter is scenery; verb
  // is on the pharmacist's body.
  pharmacy: {
    labelZh: '药店',
    size: { minW: 5, maxW: 8, minH: 3, maxH: 5 },
    layout: {
      algorithm: 'open_floor',
      items: [
        { type: 'workstation', specId: 'civilian_pharmacist', role: 'supervisor', noInteractable: true, labelZh: '药品柜台' },
      ],
    },
  },

  // South exit (primary), north entry (extra) for one-way patron traffic.
  // The cashier counter is scenery; buy-verb routes through the on-duty
  // shop_*_clerk's talk-verb (ShopkeeperConversation in NPCDialog).
  shop: {
    labelZh: '便利店',
    size: { minW: 6, maxW: 9, minH: 4, maxH: 6 },
    hasManageCell: true,
    layout: {
      algorithm: 'open_floor',
      extraDoors: [{ side: 'n', tiedToPrimary: false }],
      items: [
        { type: 'workstation', specId: 'shop_morning_clerk',   role: 'counter', noInteractable: true, labelZh: '柜台' },
        { type: 'workstation', specId: 'shop_afternoon_clerk', role: 'counter', noInteractable: true },
        { type: 'landmark', role: 'shop_counter'  },
        { type: 'landmark', role: 'shop_approach' },
        { type: 'landmark', role: 'shop_entry'    },
        { type: 'landmark', role: 'shop_exit'     },
      ],
    },
  },

  // ── OPEN FLOOR: industrial ──────────────────────────────────────────────

  // North primary + south extra tied for straight-through traffic.
  // Partition at row 3 divides manager office (above) from floor (below).
  factory: {
    labelZh: '工厂',
    size: { minW: 8, maxW: 12, minH: 8, maxH: 12 },
    layout: {
      algorithm: 'open_floor',
      primaryDoor: 'n',
      extraDoors: [{ side: 's', tiedToPrimary: true }],
      items: [
        { type: 'partition', orientation: 'h', rowFromTop: 3, doorTiedToPrimary: true },
        // The factory_manager's desk is scenery — hire-verbs render via
        // FactoryManagerConversation on the talk-verb to the seated
        // manager. spawn.ts links worker stations to this desk by
        // matching specId, not by an Interactable kind.
        { type: 'workstation', specId: 'factory_manager',        role: 'supervisor', noInteractable: true, labelZh: '经理办公桌' },
        { type: 'workstation', specId: 'factory_engineer',        role: 'worker' },
        { type: 'workstation', specId: 'factory_worker_morning',  role: 'worker' },
        { type: 'workstation', specId: 'factory_worker_early',    role: 'worker' },
        { type: 'workstation', specId: 'factory_worker_day',      role: 'worker' },
      ],
    },
  },

  // ── AIRPORT ─────────────────────────────────────────────────────────────

  // Open interior, single ticket counter; FlightHub binding done at spawn
  // (scene.id → flights.json5 hub.sceneId). Also embeds the scene's
  // `placement: 'airport'` transit terminal as a kiosk near the entrance.
  // Fixed-size 30×50 footprint — too big for any street block, so the
  // airport is placed exclusively as a procgen-zone reservedRect (the
  // road carver forces avenues/streets at its edges; spawn drops it into
  // the resulting super-block). One reservedRect entry per scene supplies
  // the tile + primary-door spec.
  airport: {
    labelZh: '航天港',
    size: { w: 30, h: 50 },
    layout: { algorithm: 'airport' },
  },

  // ── TRANSIT TERMINAL ────────────────────────────────────────────────────

  // Procgen building for the city's main bus stop. Bound 1:1 by sceneId to
  // the `placement: 'building'` terminal in transit.json5, same way airport
  // binds to a flight hub. Open interior with a single transit kiosk.
  // Kept small (3×3 minimum) so it fits the leftover sub-blocks after the
  // airport (12×8 minimum) and shop claim the bigger ones.
  transitTerminal: {
    labelZh: '换乘站',
    size: { minW: 3, maxW: 5, minH: 3, maxH: 4 },
    layout: { algorithm: 'transit' },
  },

  // ── PARK ────────────────────────────────────────────────────────────────

  // No walls, no doors — just an open rect with scattered survival
  // fixtures. Counts are uniform-random within the declared ranges.
  park: {
    labelZh: '公园',
    size: { minW: 6, maxW: 14, minH: 5, maxH: 10 },
    layout: {
      algorithm: 'park',
      taps:     { min: 1, max: 2 },
      scavenge: { min: 1, max: 2 },
      benches:  { min: 1, max: 3 },
    },
  },

  // ── CELL ALGORITHMS: residential ───────────────────────────────────────

  apartment: {
    labelZh: '公寓',
    size: { minW: 8, maxW: 12, minH: 5, maxH: 9 },
    layout: {
      algorithm: 'cells',
      minCells: 3,
      maxCells: 6,
      cellItems: [{ type: 'bed', tier: 'apartment', role: 'bed_row' }],
    },
  },

  luxury: {
    labelZh: '高级公寓',
    size: { minW: 8, maxW: 12, minH: 8, maxH: 14 },
    layout: {
      algorithm: 'cells',
      minCells: 2,
      maxCells: 4,
      cellItems: [{ type: 'bed', tier: 'luxury', role: 'bed_row' }],
    },
  },

  flop: {
    labelZh: '廉价旅馆',
    size: { minW: 5, maxW: 8, minH: 3, maxH: 5 },
    layout: {
      algorithm: 'open_floor',
      primaryDoor: 'n',
      items: [{ type: 'bed', tier: 'flop', role: 'bed_row', count: 4 }],
    },
  },

  dorm: {
    labelZh: '工人宿舍',
    size: { minW: 5, maxW: 8, minH: 3, maxH: 5 },
    layout: {
      algorithm: 'open_floor',
      primaryDoor: 'e',
      items: [{ type: 'bed', tier: 'dorm', role: 'bed_row', count: 2 }],
    },
  },

  // ── HANGAR ──────────────────────────────────────────────────────────────

  // Phase 6.2.A surface-tier hangar facility. Spawned as a fixedBuilding
  // east of the Von Braun central district (the diegetic neighbor of the
  // airport — the state hangar where civilian-grade hulls dock). The
  // facility-class shape (tier, slotCapacity) lives in facility-types.json5
  // and is attached as the Hangar trait at spawn time. Capacity-only verbs
  // ship here; ShipStatSheet + repair throughput at 6.2.B, supply/fuel at
  // 6.2.F, transfer-to-other-hangar at 6.2.G.
  //
  // stateLocked: civic infrastructure — the state-rental hangar is the
  // early-game escape valve and cannot be bought. The realtor never
  // lists it.
  hangarSurface: {
    labelZh: '机库',
    size: { w: 14, h: 14 },
    stateLocked: true,
    layout: {
      algorithm: 'open_floor',
      items: [
        { type: 'workstation', specId: 'hangar_manager', role: 'supervisor', noInteractable: true, labelZh: '机库主管' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
      ],
    },
  },

  // Phase 6.2.A.2 drydock-tier hangar facility. Capital ships base in orbit
  // (UC canon — lunar-surface industrial complexes are construction yards,
  // not parking lots), so the drydock hosts cruisers / battleships +
  // small-craft slots. Reached by riding the orbital lift up from the VB
  // spaceport; the diegetic walk to manage capital ships is "spaceport →
  // orbital-lift interactable → drydock concourse." Same facility-class
  // spine as hangarSurface — only the slot tier + scale differ.
  //
  // stateLocked: civic infrastructure — the Granada state-rental drydock is
  // the early-game escape valve for capital tonnage and cannot be bought.
  hangarDrydock: {
    labelZh: '轨道船坞',
    size: { w: 20, h: 16 },
    stateLocked: true,
    layout: {
      algorithm: 'open_floor',
      items: [
        { type: 'workstation', specId: 'hangar_manager', role: 'supervisor', noInteractable: true, labelZh: '船坞主管' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
        { type: 'workstation', specId: 'hangar_worker',  role: 'worker' },
      ],
    },
  },

  // ── CRAFTED: fixed buildings ────────────────────────────────────────────

  // relTile uses the convention: pixel = rect.x + relTile.x * TILE.
  // Half-integer values (e.g. 8.5) produce half-tile-center positions.
  aeComplex: {
    labelZh: '亚纳海姆电子',
    size: { w: 28, h: 26 },
    layout: {
      algorithm: 'crafted',
      // Door constrained to reception strip (rows 14-22) on west wall.
      doors: [{ side: 'w', offsetMinTiles: 14, offsetMaxTiles: 22 }],

      // Interior walls — positions/sizes in pixels relative to building origin.
      internalWalls: [
        // Vertical partition separating lobby (cols 0-6) from interior.
        { relPixel: { x: 192, y: 0   }, sizePx: { w: 6, h: 416 } },  // col 6, rows 0-13
        { relPixel: { x: 192, y: 448 }, sizePx: { w: 6, h: 384 } },  // col 6, rows 14-26

        // Horizontal partitions at rows 8, 13, 17 (interior only, gap at col 13).
        { relPixel: { x: 192, y: 256 }, sizePx: { w: 224, h: 6 } },  // row 8, left of gap
        { relPixel: { x: 448, y: 256 }, sizePx: { w: 416, h: 6 } },  // row 8, right of gap
        { relPixel: { x: 192, y: 416 }, sizePx: { w: 224, h: 6 } },  // row 13, left
        { relPixel: { x: 448, y: 416 }, sizePx: { w: 416, h: 6 } },  // row 13, right
        { relPixel: { x: 192, y: 544 }, sizePx: { w: 224, h: 6 } },  // row 17, left
        { relPixel: { x: 448, y: 544 }, sizePx: { w: 416, h: 6 } },  // row 17, right

        // Office column walls at cols 11, 15, 19, 23 (rows 1-8 and 8-13).
        { relPixel: { x: 352, y: 32  }, sizePx: { w: 6, h: 224 } },
        { relPixel: { x: 352, y: 256 }, sizePx: { w: 6, h: 160 } },
        { relPixel: { x: 480, y: 32  }, sizePx: { w: 6, h: 224 } },
        { relPixel: { x: 480, y: 256 }, sizePx: { w: 6, h: 160 } },
        { relPixel: { x: 608, y: 32  }, sizePx: { w: 6, h: 224 } },
        { relPixel: { x: 608, y: 256 }, sizePx: { w: 6, h: 160 } },
        { relPixel: { x: 736, y: 32  }, sizePx: { w: 6, h: 224 } },
        { relPixel: { x: 736, y: 256 }, sizePx: { w: 6, h: 160 } },

        // Lobby divider at col 13, rows 13-17.
        { relPixel: { x: 416, y: 416 }, sizePx: { w: 6, h: 128 } },
      ],

      factionGates: [
        // Faction-gated door on the vertical partition at row 13.
        { relPixel: { x: 192, y: 416 }, sizePx: { w: 6, h: 32 }, orient: 'v', faction: 'anaheim' },
      ],

      items: [
        // Reception — desk is scenery; AEConversation +
        // ShipDealerConversation render via the on-duty ae_director's
        // talk-verb in NPCDialog.
        { type: 'workstation', specId: 'ae_director', relTile: { x: 3.5, y: 13.5 }, noInteractable: true, labelZh: '前台' },

        // Board row (y = 4.5)
        { type: 'workstation', specId: 'ae_board_chair',     relTile: { x: 8.5,  y: 4.5  }, kind: 'work', labelZh: '董事办公桌' },
        { type: 'workstation', specId: 'ae_board_cfo',       relTile: { x: 12.5, y: 4.5  }, kind: 'work', labelZh: '董事办公桌' },
        { type: 'workstation', specId: 'ae_board_cto',       relTile: { x: 16.5, y: 4.5  }, kind: 'work', labelZh: '董事办公桌' },
        { type: 'workstation', specId: 'ae_board_coo',       relTile: { x: 20.5, y: 4.5  }, kind: 'work', labelZh: '董事办公桌' },
        { type: 'workstation', specId: 'ae_board_cmo',       relTile: { x: 24.5, y: 4.5  }, kind: 'work', labelZh: '董事办公桌' },

        // Manager row (y = 10.5)
        { type: 'workstation', specId: 'ae_floor_manager',   relTile: { x: 8.5,  y: 10.5 }, kind: 'work', labelZh: '经理办公桌' },
        { type: 'workstation', specId: 'ae_design_lead',     relTile: { x: 12.5, y: 10.5 }, kind: 'work', labelZh: '经理办公桌' },
        { type: 'workstation', specId: 'ae_ops_manager',     relTile: { x: 16.5, y: 10.5 }, kind: 'work', labelZh: '经理办公桌' },
        { type: 'workstation', specId: 'ae_hr_manager',      relTile: { x: 20.5, y: 10.5 }, kind: 'work', labelZh: '经理办公桌' },
        { type: 'workstation', specId: 'ae_quality_manager', relTile: { x: 24.5, y: 10.5 }, kind: 'work', labelZh: '经理办公桌' },

        // Factory floor — 5×4 grid starting at (8.5, 18.5), colStride=4, rowStride=2.
        {
          type: 'workstation_grid',
          relTile: { x: 8.5, y: 18.5 },
          cols: 5, rows: 4,
          colStride: 4, rowStride: 2,
          specIds: [
            'ae_senior_engineer', 'ae_engineer',   'ae_engineer',   'ae_engineer',   'ae_senior_engineer',
            'ae_engineer',        'ae_technician', 'ae_technician', 'ae_technician', 'ae_technician',
            'ae_technician',      'ae_assembler',  'ae_assembler',  'ae_assembler',  'ae_assembler',
            'ae_assembler',       'ae_assembler',  'ae_assembler',  'ae_assembler',  'ae_technician',
          ],
        },

        // Lounge beds (y = 15.5)
        { type: 'bed', tier: 'lounge', relTile: { x: 16, y: 15.5 } },
        { type: 'bed', tier: 'lounge', relTile: { x: 19, y: 15.5 } },
        { type: 'bed', tier: 'lounge', relTile: { x: 22, y: 15.5 } },
        { type: 'bed', tier: 'lounge', relTile: { x: 25, y: 15.5 } },

        // Amenity row (y = 14.5 for gym; y = 14 for tap/snack — tile-aligned)
        { type: 'gym_equipment', labelZh: '跑步机', relTile: { x: 8.5,  y: 14.5 } },
        { type: 'gym_equipment', labelZh: '杠铃',   relTile: { x: 10.5, y: 14.5 } },
        { type: 'gym_equipment', labelZh: '哑铃台', relTile: { x: 12.5, y: 14.5 } },
        { type: 'snack_cabinet',                    relTile: { x: 15,   y: 14   } },
        { type: 'snack_cabinet',                    relTile: { x: 22,   y: 14   } },
        { type: 'water_dispenser',                  relTile: { x: 26,   y: 14   } },
      ],
    },
  },
}

// Points of interest in the Earth Sphere campaign sector.
//
// Each POI orbits a host body declared in celestialBodies.json5. Per-frame
// world position is derivedBodyPos(host) + orbitRadius·(cosθ, sinθ) where
// θ advances by 2π / orbitPeriodDays. The POI table owns the orbital
// parameters; the engine layer (slice 3) owns the derivation.
//
// orbitRadius is small relative to a body's bodyRadius for stations
// "on" the body (Von Braun on the Moon's surface visualization sits
// just outside Moon's bodyRadius=200, at orbitRadius=180-190). For "in
// orbit" POIs (Earth low orbit, Luna II) the radius sits comfortably
// outside the host body. For Side colonies the POI orbits its own Side
// body at small radius — the Side IS a body in celestialBodies.json5
// already, and its docking POI is a small marker on top of it.
//
// `region` is preserved from the legacy starmap.json5 as metadata for
// hostile-patrol density and music cues; it's no longer used for
// runtime Voronoi encounter rolls.
//
// `encounterPoolId` field is kept on the schema for v2 wiring but
// goes unused in v1: RNG transit encounters are removed; persistent
// hand-placed enemies (data/space-entities.json5) replace them.
{
  pois: [
    // — Lunar group ————————————————————————————————————————————
    {
      id: 'vonBraun',
      nameZh: '冯·布劳恩',
      shortZh: '冯·布劳恩',
      type: 'colony',
      factionControlPre: 'civilian',
      factionControlPost: 'civilian',
      services: ['refuel', 'repair', 'store', 'hire'],
      sceneId: 'vonBraunCity',
      bodyId: 'moon',
      orbitRadius: 180,
      orbitPeriodDays: 0.5,
      orbitPhase: 0,
      region: 'lunarSphere',
      takeoffFuelCost: 12,
      description: '月面最古老的民用穹顶都市；玩家的母港。',
    },
    {
      id: 'granada',
      nameZh: '格拉纳达',
      shortZh: '格拉纳达',
      type: 'shipyard',
      factionControlPre: 'ae',
      factionControlPost: 'ae',
      services: ['refuel', 'repair', 'refit', 'hire'],
      // Phase 6.2.C2 — bind to the walkable Granada drydock scene so
      // poiIdForHangarScene('granadaDrydock') resolves to 'granada'. The
      // C1 ship-delivery + capacity-derivation surfaces both walk POIS
      // looking for this pairing; without it the drydock hangar can't
      // receive Pegasus deliveries.
      sceneId: 'granadaDrydock',
      bodyId: 'moon',
      orbitRadius: 190,
      orbitPeriodDays: 0.5,
      orbitPhase: 2.1,
      region: 'lunarSphere',
      takeoffFuelCost: 12,
      description: 'AE 月面船坞群；军舰改装、雇佣与补给中心。',
    },
    {
      id: 'lunaII',
      nameZh: '月神二号',
      shortZh: '月神二号',
      type: 'station',
      factionControlPre: 'efsf',
      factionControlPost: 'efsf',
      services: ['refuel', 'store'],
      bodyId: 'moon',
      orbitRadius: 320,
      orbitPeriodDays: 1,
      orbitPhase: 0.8,
      region: 'lunarSphere',
      takeoffFuelCost: 8,
      description: '联邦军月球后勤站；战时升级为前线基地。',
    },


// Public-transport terminals — drives the fast-travel system. Each terminal
// is a Transit entity in the world (spawned in ecs/spawn.ts) and a
// destination shown on the transit map overlay (ui/TransitMap.tsx).
//
// `placement` decides where the terminal is built:
//   'building' — procgen places a `transitTerminal` building (one per
//                scene's central/commercial district, min=max=1) and
//                spawns the kiosk inside. Bound 1:1 to this entry by
//                sceneId at spawn time. No coords here.
//   'airport'  — the airport spawn embeds this terminal as a kiosk near
//                its entrance. Bound 1:1 to this entry by sceneId at
//                spawn time. No coords here.
//   'fixed'    — coords are hard-coded below (terminalTile + arrivalTile).
//                Used for hand-placed buildings like aeComplex.
//
// All runtime positions live in sim/transitPlacements.ts; the spawn code
// registers them as it places each terminal. UI/migration read the
// registry, not these JSON5 fields.

{
  terminals: [
    // ── startTown ────────────────────────────────────────────────────────
    {
      id: 'startTownPlaza',
      sceneId: 'startTown',
      placement: 'building',
      nameZh: '市中心广场站',
      shortZh: '中心区站',
      description: '通往各地的公共交通站点。冯·布劳恩中心区的主要换乘点。',
    },
    {
      id: 'startTownAirportStop',
      sceneId: 'startTown',
      placement: 'airport',
      nameZh: '冯·布劳恩航天港站',
      shortZh: '航天港站',
      description: '冯·布劳恩航天港大厅内的换乘站。乘公交直达售票处。',
    },
    {
      id: 'aeReceptionStop',
      sceneId: 'startTown',
      placement: 'fixed',
      nameZh: '安那海姆电子前台站',
      shortZh: 'AE 前台站',
      // West of the AE complex (rect 400,200 + 28×26), on open ground
      // outside the reception door. Stays on public ground regardless of
      // future AE faction-gate tweaks.
      terminalTile: { x: 398, y: 213 },
      arrivalTile:  { x: 398, y: 214 },
      description: 'AE 总部门外的换乘站。员工和访客都可使用。',
    },

    // ── zumCity ──────────────────────────────────────────────────────────
    {
      id: 'zumCityPlaza',
      sceneId: 'zumCity',
      placement: 'building',
      nameZh: '祖姆中央广场站',
      shortZh: '中央站',
      description: '祖姆市的主要换乘点。',
    },
    {
      id: 'zumCityAirportStop',
      sceneId: 'zumCity',
      placement: 'airport',
      nameZh: '祖姆市航天港站',
      shortZh: '祖姆航天港站',
      description: '祖姆市航天港大厅内的换乘站。',
    },
  ],
}

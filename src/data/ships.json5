// Player ship class blueprints — Starsector-shape stat block.
//
// A ship's combat performance is the product of:
//   hullMax           — total hull integrity (HP). 0 = destroyed.
//   armorMax          — armor before hull damage. Reduces incoming damage
//                       proportionally to remaining armor pct.
//   fluxMax           — capacitor budget for weapon firing (and, where
//                       installed, shields).
//   fluxDissipation   — flux/sec the ship vents passively
//   hasShield         — whether the ship mounts an energy shield generator.
//                       UC default is false: ship-level energy shields don't
//                       exist in UC. The flux/shield mechanism is reserved
//                       for end-game MS that earn shield generators.
//   shieldEfficiency  — multiplier on incoming-damage flux conversion
//                       when shields are up. 1 = neutral; <1 = better.
//                       Irrelevant when hasShield = false.
//   topSpeed          — tactical-arena units/sec at full throttle
//   maneuverability   — 0..1 multiplier on turn rate
//
// Logistics (campaign map):
//   fuelMax / suppliesMax — campaign-map travel resources
//   crewMax               — hard cap on crew aboard
//
// Hardpoints (`mounts`):
//   array of `{ idx, size: 'small' | 'medium' | 'large', firingArcDeg,
//   facingDeg }`. `firingArcDeg` is the total firing arc in degrees
//   (e.g. 30 = ±15° around the mount centerline). `facingDeg` is the
//   mount center direction in degrees relative to ship heading
//   (0 = forward, +90 = starboard). Each turret on a ship can declare
//   its own arc — different mounts on the same ship can cover
//   different angles. Weapons must match or be smaller than the mount
//   size.
//
// Walkable interior:
//   rooms[]   — list of room rectangles in ship-local tile space.
//               Each room may declare interactables[] — kiosks the
//               player clicks (kind matches the InteractableKind union;
//               label is zh-CN; offset is in tiles relative to room
//               center, default {0,0}).
//   doors[]   — adjacencies between rooms (procgen/ship.ts converts to
//               Wall + Door entities). The walkable layer survives the
//               Starsector pivot because it carries downtime, mode-
//               switch transit, and story beats — but not combat UI.
//
// Phase 6.0 ships exactly one class: the light freighter the player
// buys as a Phase 6 capstone. Phase 6.2+ adds frigates / destroyers /
// carriers by appending entries here.

{
  ships: [
    {
      id: 'lightFreighter',
      nameZh: '轻型货船 · 改装型',
      descZh: 'AE 二手货船底盘改装的轻型武装船。机库勉强能容下一台 MS。',
      shipClass: 'civilian',
      hullMax: 800,
      armorMax: 200,
      fluxMax: 1500,
      fluxDissipation: 75,
      // No shield — ship-level energy shields don't exist in UC; armor +
      // hull is the entire defensive budget. Flux still gates weapon power
      // output. The shield mechanism is preserved in code for end-game MS.
      hasShield: false,
      shieldEfficiency: 1.0,
      topSpeed: 60,
      maneuverability: 0.55,
      crMax: 100,
      fuelMax: 16,
      suppliesMax: 40,
      crewMax: 4,
      mounts: [
        // Two forward small hardpoints, both narrow ±15° arcs.
        { idx: 0, size: 'small', firingArcDeg: 30, facingDeg: 0 },
        { idx: 1, size: 'small', firingArcDeg: 30, facingDeg: 0 },
      ],
      defaultWeapons: ['beamMk1'],
      priceFiat: 80000,
      rooms: [
        {
          id: 'bridge', nameZh: '舰桥', bounds: { x: 0, y: 0, w: 2, h: 2 },
          interactables: [
            { kind: 'helm', label: '操舵 / 航行', offset: { dx: 0, dy: -0.5 } },
          ],
        },
        { id: 'crewQ',      nameZh: '船员舱',   bounds: { x: 2, y: 0, w: 2, h: 2 } },
        { id: 'mess',       nameZh: '餐厅',     bounds: { x: 4, y: 0, w: 2, h: 2 } },
        { id: 'engineRoom', nameZh: '引擎室',   bounds: { x: 0, y: 2, w: 2, h: 2 } },
        { id: 'medbay',     nameZh: '医务室',   bounds: { x: 2, y: 2, w: 2, h: 2 } },
        {
          id: 'hangarBay', nameZh: '机库', bounds: { x: 4, y: 2, w: 2, h: 2 },
          interactables: [
            { kind: 'disembarkShip', label: '下船', offset: { dx: 0, dy: -0.5 } },
          ],
        },
      ],
      doors: [
        { roomA: 'bridge',     roomB: 'crewQ',      side: 'east' },
        { roomA: 'crewQ',      roomB: 'mess',       side: 'east' },
        { roomA: 'engineRoom', roomB: 'medbay',     side: 'east' },
        { roomA: 'medbay',     roomB: 'hangarBay',  side: 'east' },
        { roomA: 'bridge',     roomB: 'engineRoom', side: 'south' },
        { roomA: 'crewQ',      roomB: 'medbay',     side: 'south' },
        { roomA: 'mess',       roomB: 'hangarBay',  side: 'south' },
      ],
    },
  ],
}

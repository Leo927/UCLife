// Player ship class blueprints — Starsector-shape stat block.
//
// A ship's combat performance is the product of:
//   hullMax           — total hull integrity (HP). 0 = destroyed.
//   armorMax          — armor before hull damage. Reduces incoming damage
//                       proportionally to remaining armor pct.
//   fluxMax           — capacitor budget for weapon firing (and, where
//                       installed, shields).
//   fluxDissipation   — flux/sec the ship vents passively
//   hasShield         — whether the ship mounts an energy shield generator.
//                       UC default is false: ship-level energy shields don't
//                       exist in UC. The flux/shield mechanism is reserved
//                       for end-game MS that earn shield generators.
//   shieldEfficiency  — multiplier on incoming-damage flux conversion
//                       when shields are up. 1 = neutral; <1 = better.
//                       Irrelevant when hasShield = false.
//   topSpeed          — tactical-arena units/sec at full throttle (hard cap)
//   accel             — linear thrust acceleration (arena units/sec²) when WASD input is held
//   decel             — passive deceleration applied when no thrust input — gives the ship inertia + glide
//   angularAccel      — radians/sec² of steering torque (used both to spin the
//                       helm toward the aim cursor and to bleed off angular velocity when idle)
//   maxAngVel         — radians/sec hard cap on angular velocity (turn rate ceiling)
//
// AI block (`ai`):
//   When the player provides no movement input, the player's ship runs the
//   same AI loop as enemies — closing to / strafing at / backing away from
//   maintainRange relative to the nearest hostile. Player input/aim
//   overrides this directive on the player ship; enemies always run AI.
//   aggression           — weapon-charge multiplier (0..1; not used for player firing).
//   retreatThresholdPct  — hull % below which AI flees (0..1; not yet wired for player).
//   maintainRange        — preferred standoff distance from the nearest hostile, arena units.
//
// Logistics (campaign map):
//   fuelMax / suppliesMax — campaign-map travel resources
//   crewMax               — hard cap on crew aboard
//
// Hardpoints (`mounts`):
//   array of `{ idx, size: 'small' | 'medium' | 'large', firingArcDeg,
//   facingDeg }`. `firingArcDeg` is the total firing arc in degrees
//   (e.g. 30 = ±15° around the mount centerline). `facingDeg` is the
//   mount center direction in degrees relative to ship heading
//   (0 = forward, +90 = starboard). Each turret on a ship can declare
//   its own arc — different mounts on the same ship can cover
//   different angles. Weapons must match or be smaller than the mount
//   size.
//
// Walkable interior:
//   rooms[]   — list of room rectangles in ship-local tile space.
//               Each room may declare interactables[] — kiosks the
//               player clicks (kind matches the InteractableKind union;
//               label is zh-CN; offset is in tiles relative to room
//               center, default {0,0}).
//   doors[]   — adjacencies between rooms (procgen/ship.ts converts to
//               Wall + Door entities). The walkable layer survives the
//               Starsector pivot because it carries downtime, mode-
//               switch transit, and story beats — but not combat UI.
//
// Phase 6.0 ships exactly one class: the light freighter the player
// buys as a Phase 6 capstone. Phase 6.2+ adds frigates / destroyers /
// carriers by appending entries here.

{
  ships: [
    {
      id: 'lightFreighter',
      nameZh: '轻型货船 · 改装型',
      descZh: 'AE 二手货船底盘改装的轻型武装船。机库勉强能容下一台 MS。',
      shipClass: 'civilian',
      hullMax: 800,
      armorMax: 200,
      fluxMax: 1500,
      fluxDissipation: 75,
      // No shield — ship-level energy shields don't exist in UC; armor +
      // hull is the entire defensive budget. Flux still gates weapon power
      // output. The shield mechanism is preserved in code for end-game MS.
      hasShield: false,
      shieldEfficiency: 1.0,
      topSpeed: 60,
      accel: 60,
      decel: 30,
      angularAccel: 4.0,
      maxAngVel: 1.5,
      crMax: 100,
      fuelMax: 16,
      suppliesMax: 40,
      crewMax: 4,
      // Civilian-spec hulls in the design get brigCapacity: 0; the
      // lightFreighter ships a refit 2-cell brig so the named-hostile
      // capture loop has somewhere to go in 6.2. A clean civilian
      // variant — when added — would set brigCapacity: 0.
      brigCapacity: 2,
      // Bridge officer roster. 6.2 wires the adjutant only — comm-panel
      // chatter (launch, dock, threshold, leave-bridge) reads the name
      // from here instead of the 6.1 hardcoded "凯文". 6.2.5 expands the
      // officer wall with chief mech / chief medical / etc.
      officers: {
        adjutant: { name: '凯文', title: '副官' },
      },
      mounts: [
        // Two forward small hardpoints, both narrow ±15° arcs.
        { idx: 0, size: 'small', firingArcDeg: 30, facingDeg: 0 },
        { idx: 1, size: 'small', firingArcDeg: 30, facingDeg: 0 },
      ],
      defaultWeapons: ['beamMk1'],
      ai: {
        aggression: 0.5,
        retreatThresholdPct: 0.2,
        // Light freighter prefers a brawler standoff range — same band as
        // pirateLight so a no-input player and a default enemy meet midway.
        maintainRange: 200,
      },
      priceFiat: 80000,
      // Captain's office sits in its own row above the bridge so it's
      // adjacent (south door into the bridge). Hosts two kiosks: the
      // readiness-summary desk (Phase 6.0) and the comm panel (Phase
      // 6.2 — officer chatter, named-hostile context; prisoner verbs
      // land at 6.2.5). The brig is two doors aft of the captain's
      // office; the player walks from desk → comm to brig in roughly
      // a hallway's length, so the captain ↔ POW loop reads diegetic.
      rooms: [
        {
          id: 'captainsOffice', nameZh: '船长室', bounds: { x: 0, y: 0, w: 2, h: 2 },
          interactables: [
            { kind: 'captainsDesk', label: '出航简报', offset: { dx: -0.5, dy: -0.5 } },
            { kind: 'commPanel',    label: '通讯面板', offset: { dx: 0.5,  dy: -0.5 } },
          ],
        },
        {
          id: 'bridge', nameZh: '舰桥', bounds: { x: 0, y: 2, w: 2, h: 2 },
          interactables: [
            { kind: 'helm', label: '操舵 / 航行', offset: { dx: 0, dy: -0.5 } },
          ],
        },
        { id: 'crewQ',      nameZh: '船员舱',   bounds: { x: 2, y: 2, w: 2, h: 2 } },
        { id: 'mess',       nameZh: '餐厅',     bounds: { x: 4, y: 2, w: 2, h: 2 } },
        { id: 'engineRoom', nameZh: '引擎室',   bounds: { x: 0, y: 4, w: 2, h: 2 } },
        { id: 'medbay',     nameZh: '医务室',   bounds: { x: 2, y: 4, w: 2, h: 2 } },
        {
          id: 'hangarBay', nameZh: '机库', bounds: { x: 4, y: 4, w: 2, h: 2 },
          interactables: [
            { kind: 'disembarkShip', label: '下船', offset: { dx: 0, dy: -0.5 } },
            // Phase 6.1 — climb into the on-ship MS. Visible at all
            // times; the interaction handler gates the actual launch
            // on combat being engaged. Pre-combat clicks just toast.
            { kind: 'climbIntoMs', label: '登舱出击', offset: { dx: 0.5, dy: 0.5 } },
          ],
        },
        // Phase 6.2 — brig as ship-class room. Capacity is gated by
        // brigCapacity above; per-prisoner verbs (interrogate / ransom
        // / etc.) land at 6.2.5. The 'brig' interactable opens the
        // occupant list panel. Sits east of the captain's office on
        // the top row so the captain ↔ POW loop is a one-door walk.
        {
          id: 'brig', nameZh: '禁闭室', bounds: { x: 2, y: 0, w: 2, h: 2 },
          interactables: [
            { kind: 'brig', label: '查看囚犯', offset: { dx: 0, dy: -0.5 } },
          ],
        },
      ],
      doors: [
        { roomA: 'captainsOffice', roomB: 'bridge',   side: 'south' },
        { roomA: 'captainsOffice', roomB: 'brig',     side: 'east' },
        { roomA: 'brig',       roomB: 'crewQ',      side: 'south' },
        { roomA: 'bridge',     roomB: 'crewQ',      side: 'east' },
        { roomA: 'crewQ',      roomB: 'mess',       side: 'east' },
        { roomA: 'engineRoom', roomB: 'medbay',     side: 'east' },
        { roomA: 'medbay',     roomB: 'hangarBay',  side: 'east' },
        { roomA: 'bridge',     roomB: 'engineRoom', side: 'south' },
        { roomA: 'crewQ',      roomB: 'medbay',     side: 'south' },
        { roomA: 'mess',       roomB: 'hangarBay',  side: 'south' },
      ],
    },
  ],
}

// Ship hardpoint weapons — Starsector-shape stat block.
//
// Schema (see weapons.ts for the typed shape):
//   id            — stable key
//   nameZh        — zh-CN name
//   descZh        — zh-CN one-liner
//   type          — 'beam' | 'ballistic' | 'missile' | 'mega'
//   size          — 'small' | 'medium' | 'large' (hardpoint size cap)
//   damage        — per-shot damage
//   range         — max effective range in tactical-arena units
//   chargeSec     — seconds-of-charge between shots (real-time, in-combat)
//   fluxPerShot   — flux generated by the firing ship per shot
//   shieldDamage  — multiplier on damage vs. shields (default 1)
//   armorDamage   — multiplier on damage vs. armor (default 1)
//   projectileSpeed — for ballistic/missile; 0 for instant beams
//   tracking      — 0..1 how well the weapon tracks evading targets
//   tier          — 1..3 tech tier; gates store availability
//   cost          — fiat market price; 0 = enemy-only (never sold)
//
// Phase 6.0 ships starter small beams + missiles. Larger weapons + flak
// + mega-particle land in 6.2+ when frigates/destroyers arrive.

{
  weapons: [
    {
      id: 'beamMk1',
      nameZh: '标准光束炮',
      descZh: '米诺夫斯基聚束式光束炮；命中即时，对护盾低效。',
      type: 'beam',

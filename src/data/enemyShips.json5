// Enemy ship class library — Starsector-shape stat block.
//
// Schema (see enemyShips.ts):
//   id, nameZh, descZh
//   hullMax, armorMax, fluxMax, fluxDissipation, shieldEfficiency
//   topSpeed, maneuverability
//   mounts[]   — same hardpoint shape as ships.json5
//   defaultWeapons[] — ordered list bound to mounts
//   ai — { aggression: 0..1, retreatThresholdPct: 0..1, maintainRange: number }
//
// Phase 6.0 spine ships one class — the pirate light frigate from
// `pirate_patrol`. Tuning is deliberately weak: a freshly-bought
// lightFreighter beats it cleanly, so the player learns the controls
// without losing the ship on first contact.

{
  ships: [
    {
      id: 'pirateLight',
      nameZh: '海盗轻型护卫舰',
      descZh: '老旧的吉翁式轻型护卫舰，被海盗改装。',
      hullMax: 500,
      armorMax: 100,
      fluxMax: 1000,
      fluxDissipation: 50,
      shieldEfficiency: 1.2,    // worse-than-neutral; takes more flux per damage
      topSpeed: 70,
      maneuverability: 0.65,
      mounts: [
        { idx: 0, size: 'small', arc: 1.2, facing: 0 },
        { idx: 1, size: 'small', arc: 1.0, facing: 0 },
      ],
      defaultWeapons: ['pirateBeamMk0', 'pirateBeamMk0'],
      ai: {
        aggression: 0.55,
        retreatThresholdPct: 0.2,
        // Distance the AI tries to maintain from the player ship in arena
        // units. Pirate light frigates close in to brawling range.
        maintainRange: 160,
      },
    },
  ],
}

// Scene registry — every separate world (city, colony, ship interior, …) is
// a row here. Each entry is a self-contained coordinate space: tile origin
// (0,0) up to (tilesX, tilesY), its own koota World, its own pathfinding
// graph, its own NPC roster.
//
// Fields (all scenes):
//   id          — unique scene id. Referenced by data/flights.json5 (sceneId
//                 on each hub). Cross-data references are validated at load
//                 time.
//   titleZh     — player-facing name shown in the HUD title.
//   sceneType   — 'micro': top-down human-scale city.
//                 'macro': MS/warship/fighter scale (future).
//                 'ship':  player-ship interior; bootstraps from
//                          src/data/ship-classes.json5 via shipClassId.
//   tilesX/Y    — logical envelope in tiles. Camera bounds, grid lines,
//                 click clamping, pathfinding, and the map panel viewBox.
//   playerSpawnTile — initial player position (tile coords). Only meaningful
//                 for the first scene in declaration order.
//
// Fields (micro scenes):
//   replenishment — opt-in NPC auto-spawn config. Omit to disable. Fields:
//                   target (alive-NPC count to maintain) and arrivalTile
//                   (walkable street tile, in this scene's tile-space, where
//                   each new immigrant appears). Throttle interval is global
//                   (config/population.json5: replenishIntervalMin).
//   procgenZones — array of road-based city generators, one per spatially
//                  distinct sector. Zone rects must not overlap each other
//                  or any fixedBuilding rect (the road carver doesn't know
//                  about holes).
//     enabled     — explicit on/off flag.
//     seed        — deterministic RNG seed string. Same seed → same layout.
//     rect        — tile-space area for the road network + buildings
//                   { x, y, w, h }. Avoid placing fixedBuildings inside.
//     roads       — Manhattan grid params (avenueSpacingTiles, etc.).
//     districts   — zoning rectangles in tile-space *relative to the
//                   zone rect origin*. Each sub-block picks the district
//                   whose rect contains the sub-block center.
//       id, rect{x,y,w,h}, types[], buildingsPerBlockMax (default 1)
//       types[]   — array of `{ id, min?, max? }`. min defaults to 0
//                   (place opportunistically), max defaults to unbounded
//                   (place freely). Use min ≥ 1 to mandate placement.
//                   Buildings too big for a single street block (e.g.
//                   the 30×50 airport) belong in reservedRects, not here.
//     reservedRects — fixed-size buildings that live *inside* the zone.
//                   Procgen forces avenues/streets at the rect's edges so
//                   it emerges as a single uncarved super-block, then
//                   spawn drops the building there. Use this for any
//                   facility too large to host inside a single street block
//                   (e.g. AE Complex, the 30×50 airport).
//                   { buildingType, tile:{x,y}, door?, display? } — size
//                   comes from buildingTypes. Crafted layouts pull doors
//                   from buildingTypes; non-crafted layouts (airport,
//                   transit, open_floor, park) MUST supply `door:
//                   { side, offsetTiles? }`. display attaches a world-map
//                   marker over the building footprint.
//     display     — optional player-facing marker. When present, MapPanel
//                   renders a marker covering the zone's `rect` with the
//                   given { id, nameZh, shortZh, description?, kind }.
//   fixedBuildings — hand-placed buildings not subject to procgen.
//     type, tile{x,y}.
//
// Fields (ship scenes):
//   shipClassId       — refs src/data/ship-classes.json5. The bootstrap reads
//                       rooms / mounts / defaultWeapons from there.
//                       tilesX/tilesY must be wide enough to contain
//                       every room with a small camera margin.
//   playerSpawnRoomId — must match a room id on the chosen ship class;
//                       boardShip() drops the player at this room's center.

{
  scenes: [
    {
      id: 'vonBraunCity',
      titleZh: '冯·布劳恩月面市',
      sceneType: 'micro',
      tilesX: 800,
      tilesY: 520,
      // West of the central procgen zone, on open ground. Player walks east
      // into the city's road network.
      playerSpawnTile: { x: 20, y: 50 },

      // Same walkable street tile the homeless player spawns on — keeps
      // immigrants on the road network so their first BT tick has a path.
      replenishment: {
        target: 30,
        arrivalTile: { x: 20, y: 16 },
      },

      procgenZones: [
        // ── Von Braun central district ────────────────────────────────────
        {
          enabled: true,
          // 100 × 80 procgen area; AE Industrial District (with the
          // AE Complex inside it) sits ~250 tiles east of here.
          seed: 'von-braun-001',
          rect: { x: 40, y: 4, w: 100, h: 80 },
          display: {
            id: 'vonBraunCity',
            nameZh: '冯·布劳恩中心区',
            shortZh: '中心区',
            kind: 'district',
            description: '商业、居住和工厂集中的城市中心。新人在公寓与廉价旅馆之间的街道上初次降生于此。',
          },
          // Tighter than the AE/Zum zones — central Von Braun is the densest
          // sector: narrower avenues, smaller blocks, more alleys, smaller
          // alley splits. The 30×50 airport sits as a reservedRect so it
          // doesn't have to fit in a street block.
          roads: {
            avenueSpacingTiles: { min: 12, max: 16 },
            streetSpacingTiles: { min: 8, max: 12 },
            avenueWidthTiles: 2,
            streetWidthTiles: 2,
            alleyChance: 0.75,
            alleyWidthTiles: 1,
            alleyMinBlockTiles: 8,
          },
          // 30×50 airport reserved rect: zone is (40,4)..(140,84); rect
          // sits at the east edge (108,10)..(138,60), leaving 2-tile road
          // buffers on every edge. The airport eats most of the
          // residential_east band (and a sliver of residential_south)
          // but stays clear of commercial so its mandatory buildings
          // still have room. Door faces west onto the forced avenue at
          // x=106, so passengers spill out toward the city core.
          reservedRects: [
            {
              buildingType: 'airport',
              tile: { x: 108, y: 10 },
              door: { side: 'w', offsetTiles: 25 },
              display: {
                id: 'vonBraunCityAirport',
                nameZh: '冯·布劳恩航天港',
                shortZh: '航天港',
                kind: 'complex',
                description: '中心区东侧的大型航天港,直通月面外其他城市与殖民地。',
              },
            },
          ],
          // Districts (rects relative to zone rect origin).
          // Layout: commercial core near spawn (top-center), residential ring
          // around it, industrial along the south band.
          districts: [
            {
              id: 'commercial',
              rect: { x: 30, y: 0, w: 40, h: 24 },
              // Mandatory placements: shop and bar drive NPC behavior trees
              // (shopCounter / barCounter landmarks); hrOffice + realtor
              // are gameplay anchors; clinic + pharmacy gate the physiology
              // cure flow (doctor diagnosis + treatment / OTC). Park is
              // opportunistic. The transitTerminal lives in residential_north
              // because commercial is too dense to fit it alongside the
              // airport reliably. The airport itself is a reservedRect on
              // the zone (30×50 — too big for any street block).
              types: [
                { id: 'shop',            min: 1},
                { id: 'bar',             min: 1 },
                { id: 'hrOffice',        min: 1, max: 1 },
                { id: 'realtor',         min: 1, max: 1 },
                { id: 'clinic',          min: 1, max: 1 },
                { id: 'pharmacy',        min: 1, max: 1 },
                { id: 'factionOffice',   min: 1, max: 1 },
                { id: 'recruitOffice',   min: 1, max: 1 },
                { id: 'researchLab',     min: 1, max: 1 },
                { id: 'park',            max: 0 },
              ],
              buildingsPerBlockMax: 6,
            },
            {
              id: 'residential_north',
              rect: { x: 0, y: 0, w: 30, h: 40 },
              types: [
                { id: 'transitTerminal', min: 1, max: 1 },
                { id: 'park',      min: 0, max: 2 },
                { id: 'apartment', min: 0, max: 12 },
                { id: 'luxury',    min: 0, max: 3 },
                { id: 'dorm',      min: 0, max: 6 },
              ],
              buildingsPerBlockMax: 5,
            },
            {
              id: 'residential_east',
              rect: { x: 70, y: 0, w: 30, h: 40 },
              types: [
                { id: 'park',      min: 0, max: 2 },
                { id: 'apartment', min: 0, max: 12 },
                { id: 'luxury',    min: 0, max: 3 },
                { id: 'dorm',      min: 0, max: 6 },
              ],
              buildingsPerBlockMax: 5,
            },
            {
              id: 'residential_south',
              rect: { x: 20, y: 40, w: 60, h: 25 },
              types: [
                { id: 'park',      min: 0, max: 2 },
                { id: 'apartment', min: 0, max: 16 },
                { id: 'dorm',      min: 0, max: 10 },
                { id: 'flop',      min: 0, max: 8 },
              ],
              buildingsPerBlockMax: 5,
            },
            {
              id: 'industrial',
              rect: { x: 0, y: 65, w: 100, h: 15 },
              types: [
                { id: 'factory', min: 0, max: 15 },
              ],
              buildingsPerBlockMax: 5,
            },
          ],
        },

        // (Von Braun state hangar lands as a fixedBuilding east of this
        // zone — see fixedBuildings below.)

        // ── AE Industrial District ────────────────────────────────────────
        // Self-contained sector built around the AE Complex. The complex
        // (28×26, crafted) sits at tile (400, 200) as a reservedRect — the
        // road grid forces avenues/streets along its edges so it emerges
        // as a single uncarved super-block, with the rest of the zone
        // (worker housing, convenience commerce, subcontractor factories)
        // generated around it. AE's reception door faces west, so workers
        // and visitors step out the lobby straight onto the forced west
        // avenue at (398..400). The district's transitTerminal building
        // (binds to aeIndustrialStop) is mandated in the commercial band
        // so procgen drops a kiosk somewhere along the worker-route.
        {
          enabled: true,
          seed: 'ae-industrial-001',
          rect: { x: 302, y: 180, w: 132, h: 60 },
          display: {
            id: 'aeIndustrialDistrict',
            nameZh: 'AE 工业区',
            shortZh: 'AE 工业区',
            kind: 'district',
            description: '安那海姆电子总部周边的工业区：员工公寓、便利店、酒吧和承包商工厂围绕着 AE 总部展开。',
          },
          roads: {
            avenueSpacingTiles: { min: 14, max: 18 },
            streetSpacingTiles: { min: 10, max: 14 },
            avenueWidthTiles: 2,
            streetWidthTiles: 2,
            alleyChance: 0.5,
            alleyWidthTiles: 1,
            alleyMinBlockTiles: 9,
          },
          reservedRects: [
            {
              buildingType: 'aeComplex',
              tile: { x: 400, y: 200 },
              display: {
                id: 'aeComplex',
                nameZh: '安那海姆电子总部',
                shortZh: 'AE 总部',
                kind: 'complex',
                description: 'AE 工业区的核心：安那海姆电子的庞大企业园区。前台面向工业区，董事会、车间、健身房、休息室都在这一栋楼里。',
              },
            },
          ],
          districts: [
            // North band: mixed-tier housing for AE workers.
            {
              id: 'aeIndustrial_residential',
              rect: { x: 0, y: 0, w: 132, h: 24 },
              types: [
                { id: 'apartment', min: 0, max: 4 },
                { id: 'luxury',    min: 0, max: 2 },
                { id: 'dorm',      min: 0, max: 3 },
                { id: 'flop',      min: 0, max: 2 },
                { id: 'park',      min: 0, max: 1 },
              ],
              buildingsPerBlockMax: 1,
            },
            // Middle band: convenience commerce for the workforce.
            {
              id: 'aeIndustrial_commercial',
              rect: { x: 0, y: 24, w: 132, h: 14 },
              types: [
                { id: 'shop',            min: 1, max: 2 },
                { id: 'bar',             min: 0, max: 1 },
                { id: 'transitTerminal', min: 1, max: 1 },
              ],
              buildingsPerBlockMax: 1,
            },
            // South band: subcontractor factories supplying the AE plant.
            {
              id: 'aeIndustrial_industrial',
              rect: { x: 0, y: 38, w: 132, h: 22 },
              types: [
                { id: 'factory', min: 0, max: 4 },
              ],
              buildingsPerBlockMax: 1,
            },
          ],
        },
      ],

      // Phase 6.2.A — state-rental surface hangar. Sits east of the
      // central procgen zone (40,4..140,84), diegetically adjacent to the
      // airport (108,10..138,60) — civilian-grade hulls dock here. Door
      // faces west toward the airport; player walks east from the
      // spaceport to reach it.
      fixedBuildings: [
        {
          type: 'hangarSurface',
          tile: { x: 150, y: 16 },
          door: { side: 'w', offsetTiles: 6 },
          display: {
            id: 'vonBraunStateHangar',
            nameZh: '冯·布劳恩国营机库',
            shortZh: '国营机库',
            kind: 'complex',
            description: '冯·布劳恩国营的小型机库——民用机型在这里租借泊位。机库主管和技工守在这里，每天调度泊位和补给。',
          },
        },
      ],
    },

    {
      id: 'zumCity',
      titleZh: '祖姆市 · Side 3',
      sceneType: 'micro',
      tilesX: 300,
      tilesY: 300,

      procgenZones: [
        {
          enabled: true,
          seed: 'zum-city-001',
          // Smaller, denser colony interior — Side 3 is industrial Zeon.
          rect: { x: 4, y: 4, w: 70, h: 60 },
          display: {
            id: 'zumCity',
            nameZh: '祖姆市 · Side 3 共和国首府',
            shortZh: '祖姆市',
            kind: 'district',
            description: 'Side 3 殖民卫星群中代表性最强的一座 — 吉翁共和国首府祖姆市。城市中央设有同等规模的航天港。',
          },
          roads: {
            avenueSpacingTiles: { min: 12, max: 18 },
            streetSpacingTiles: { min: 10, max: 14 },
            avenueWidthTiles: 2,
            streetWidthTiles: 2,
            alleyChance: 0.7,
            alleyWidthTiles: 1,
            alleyMinBlockTiles: 9,
          },
          // 30×50 airport reserved rect: zone is (4,4)..(74,64); rect sits
          // at (20,8)..(50,58) so road buffers fit on every edge. Door
          // faces south onto the forced street at y=58, opening toward
          // the residential and industrial bands.
          reservedRects: [
            {
              buildingType: 'airport',
              tile: { x: 20, y: 8 },
              door: { side: 's', offsetTiles: 15 },
              display: {
                id: 'zumCityAirport',
                nameZh: '祖姆市航天港',
                shortZh: '祖姆航天港',
                kind: 'complex',
                description: 'Side 3 共和国首府的中央航天港,占据城市核心。',
              },
            },
          ],
          districts: [
            {
              id: 'commercial',
              rect: { x: 18, y: 0, w: 38, h: 24 },
              types: [
                { id: 'shop',            min: 1, max: 1 },
                { id: 'transitTerminal', min: 1, max: 1 },
                { id: 'bar',             min: 0, max: 1 },
                { id: 'hrOffice',        min: 0, max: 1 },
                { id: 'park',            min: 0, max: 1 },
              ],
              buildingsPerBlockMax: 1,
            },
            {
              id: 'residential',
              rect: { x: 0, y: 0, w: 70, h: 40 },
              types: [
                { id: 'park',      min: 0, max: 2 },
                { id: 'apartment', min: 0, max: 6 },
                { id: 'dorm',      min: 0, max: 4 },
                { id: 'flop',      min: 0, max: 3 },
              ],
              buildingsPerBlockMax: 1,
            },
            {
              id: 'industrial',
              rect: { x: 0, y: 40, w: 70, h: 20 },
              types: [
                { id: 'factory', min: 0, max: 6 },
              ],
              buildingsPerBlockMax: 1,
            },
          ],
        },
      ],
    },

    {
      id: 'playerShipInterior',
      titleZh: '玩家飞船 · 内部',
      sceneType: 'ship',
      shipClassId: 'lightFreighter',
      // lightFreighter rooms span 6×6 tiles (captain's office row above
      // the 3×2 main grid); envelope below leaves margin for camera
      // bounds and Slice J's exterior walls/airlock.
      tilesX: 24,
      tilesY: 16,
      playerSpawnRoomId: 'bridge',
    },

    {
      id: 'spaceCampaign',
      titleZh: '太空 · 地球圈',
      // sceneType='space' is declared in scenes.ts in slice 4. Content
      // sources are celestialBodies.json5 + pois.json5 + space-entities.json5;
      // there is no procgen, no walls, no fixedBuildings.
      sceneType: 'space',
      tilesX: 30000,
      tilesY: 24000,
    },
  ],
}

// Ship subsystem definitions. Each entry describes one of the FTL-shape
// systems a ship class can install (e.g. shields, engines, weapons). UC
// names are zh-CN and Gundam-flavored; ids and structural fields stay
// English. See Design/combat.md "FTL → UC system mapping" for the
// canonical mapping and Design/combat.md phasing for the 6.0 spine
// (six core systems below; medbay/sensors/doors/hacking/cloaking/
// teleporter ship in Phase 6.1+).
//
// Schema (see shipSystems.ts for the typed shape):
//   id              — stable string key (SystemId union)
//   nameZh          — player-facing zh-CN system name
//   descZh          — player-facing zh-CN one-liner
//   maxLevel        — purchaseable upgrade ceiling
//   powerPerLevel   — reactor cost to bring this system up by one level
//   category        — 'core' | 'optional' (Phase 6.1+ ships add optional
//                     systems; 6.0 spine treats every system as core)
//   damageStages    — sorted list of integrity thresholds (percent of
//                     system HP) that drop effective level. Canonical
//                     FTL behavior: at 50% integrity the system runs
//                     one level below installed; at 0% it is offline.
//                     `effectiveLevelDelta` is added to the installed
//                     level — so -1 means "operates one level below
//                     installed", and a very-negative value (e.g. -99)
//                     forces offline.
//
// References (read but don't copy): FTL-Hyperspace Systems.h,
// CustomReactor.h, libzhlgen ShipSystem.zhl.

{
  systems: [
    {
      id: 'shields',
      nameZh: '能量护盾',
      descZh: '米诺夫斯基饱和力场，每级提供一层护盾。',
      maxLevel: 4,
      powerPerLevel: 2,
      category: 'core',
      damageStages: [
        { thresholdPct: 50, effectiveLevelDelta: -1 },
        { thresholdPct: 0, effectiveLevelDelta: -99 },
      ],
    },
    {
      id: 'engines',
      nameZh: '推进器',
      descZh: '主推与姿控。等级越高规避越好，跃迁充能越快。',
      maxLevel: 4,
      powerPerLevel: 1,
      category: 'core',
      damageStages: [
        { thresholdPct: 50, effectiveLevelDelta: -1 },
        { thresholdPct: 0, effectiveLevelDelta: -99 },
      ],
    },
    {
      id: 'oxygen',
      nameZh: '生命维持',
      descZh: '为已连通的舱室补氧；故障时全船氧气持续下降。',
      maxLevel: 3,
      powerPerLevel: 1,
      category: 'core',
      damageStages: [
        { thresholdPct: 50, effectiveLevelDelta: -1 },
        { thresholdPct: 0, effectiveLevelDelta: -99 },
      ],
    },
    {
      id: 'weapons',
      nameZh: '武器系统',
      descZh: '为挂载的舰载武器供电；每件武器按其功耗扣减可用电力。',
      maxLevel: 4,
      powerPerLevel: 1,
      category: 'core',
      damageStages: [
        { thresholdPct: 50, effectiveLevelDelta: -1 },
        { thresholdPct: 0, effectiveLevelDelta: -99 },
      ],
    },
    {
      id: 'hangar',
      nameZh: '机库',
      descZh: 'MS 出击与回收。等级决定可同时部署的 MS 数与回收周期。',
      maxLevel: 3,
      powerPerLevel: 2,
      category: 'core',
      damageStages: [
        { thresholdPct: 50, effectiveLevelDelta: -1 },
        { thresholdPct: 0, effectiveLevelDelta: -99 },
      ],
    },
    {
      id: 'pilot',
      nameZh: '舰桥',
      descZh: '操舵席与战术官位。被动加成全船规避，并提供战术官加成槽。',
      maxLevel: 3,
      powerPerLevel: 1,
      category: 'core',
      damageStages: [
        { thresholdPct: 50, effectiveLevelDelta: -1 },
        { thresholdPct: 0, effectiveLevelDelta: -99 },
      ],
    },
  ],
}

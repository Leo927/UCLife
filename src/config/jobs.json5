    // ─── 亚纳海姆电子 (Anaheim Electronics) career ladder ─────────────────────
    //
    // Four player-hireable ranks share family='anaheim_engineering' and
    // employer='anaheim'. Promotions go through the in-building AE reception
    // desk (NPC-only ae_director spec); the city HR window filters these out
    // so AE feels like a faction with its own gate from day one.
    //
    // Gate ramp:
    //   rank 1 (装配工)         : skill-only — open to everyone, easy onramp
    //   rank 2 (技术员)         : skill-only — first proof-of-competence step
    //   rank 3 (工程师)         : skill + AE rep gate — faction loyalty matters
    //   rank 4 (高级工程师)     : skill + rep + befriend an AE board member
    //                              (forces engagement with the relations system)
    //
    // Wage scaling deliberately steeper than factory's 100→190 jump so the
    // climb feels worthwhile.

    ae_assembler: {
      jobTitle: '装配工',
      wage: 80,
      skillXp: 40,
      skill: 'mechanics',
      shiftStart: 9,
      shiftEnd: 17,
      workDays: [1, 2, 3, 4, 5],
      requirements: {},
      description: 'AE 工坊基础装配 · 入门岗位。',
      playerHireable: true,
      family: 'anaheim_engineering',
      rank: 1,
      employer: 'anaheim',
    },

    ae_technician: {
      jobTitle: '技术员',
      wage: 130,
      skillXp: 60,
      skill: 'mechanics',
      shiftStart: 9,
      shiftEnd: 17,
      workDays: [1, 2, 3, 4, 5],
      requirements: { mechanics: 15 },
      description: '维护与调试 · 装配工的下一步。',
      playerHireable: true,
      family: 'anaheim_engineering',
      rank: 2,
      employer: 'anaheim',
    },

    ae_engineer: {
      jobTitle: '工程师',

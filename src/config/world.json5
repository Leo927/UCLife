// Spatial constants — tile size, wall thickness, base movement speed, and
// the various "close enough" distances used by movement, pathfinding, and
// player/NPC interaction range checks.
{
  // Grid size in pixels. The map, all building rects, bed/desk positions,
  // and the pathfinder's underlying grid all key off this. Halving it
  // doubles map detail at the cost of CPU.
  tilePx: 32,

  // Per-scene map size in tiles lives in src/data/scenes.json5 (each scene
  // declares its own tilesX/tilesY). Camera, grid, pathfinder, and map UI
  // all read the active scene's dims — see src/ecs/world.ts.

  // Wall thickness in pixels. Walls always sit *fully inside* the building
  // footprint so their 6px band stays within a single 16-px pathfinding
  // cell row/column — see comment in ecs/spawn.ts.
  wallThicknessPx: 6,

  // Base movement speed: how many pixels an entity covers per game-minute
  // at "1× character speed". Modified per-entity by Reflex (statMult).
  movePxPerGameMin: 64,

  // Numerical guards used by the movement system. arriveEps = "treat as
  // arrived"; waypointEps = "advance to next waypoint" tolerance. Tweaking
  // these affects pathfinding stability, not gameplay feel.
  arriveEpsPx: 0.5,
  waypointEpsPx: 2,

  // Press-and-hold ground-click drives the player to the cursor every move
  // event; this threshold avoids re-running findPath() for sub-tile mouse
  // jitter. Re-target only fires when the cursor has moved at least this
  // many world pixels from the last issued destination.
  holdMoveRetargetPx: 16,

  // Range checks (in pixels). Each describes a different relationship —
  // edit independently if you want, e.g., to make the player able to use
  // distant interactables without making NPCs count as "at" their station.
  ranges: {
    // How close the player must walk to an Interactable to fire it.
    playerInteract: 28,
    // How close an NPC's position must be to a service counter for the
    // counter to count as "staffed" (shop / bar open).
    counterStaffed: 6,
    // How close an NPC's position must be to a workstation for the
    // station to count as "occupied" (interaction.ts player checks).
    workstationOccupied: 6,
    // Distance at which an NPC counts as "at" a target (BT goTo* steps).
    npcArrive: 4,
    // Distance at which an NPC counts as "at" a service counter (BT
    // shop/bar visits).
    npcCounter: 6,
  },

  // Click-feedback ripple shown at the right-click navigate point on the
  // map panel (src/ui/MapPanel.tsx). Pure UI feedback so the player sees
  // their click registered before they close the panel and their avatar
  // starts walking on the ground scene.
  mapClickFeedback: {
    // SVG <animate> dur in seconds.
    durationSec: 0.5,
    // Ripple ring radii in tile units; max() with 1/scale-derived floors
    // is applied at render time so it stays visible at every zoom.
    startRadiusTiles: 1.5,
    endRadiusTiles: 7,
    // Stroke width baseline (divided by scale at render time).
    strokeWidthBase: 1.6,
    // Initial alpha; ends at 0.
    startAlpha: 0.95,
    // Hex color (CSS string). Matches the ground-scene destination ring.
    colorCss: '#ffaa00',
  },

  // Active-zone optimization. NPCs whose Position lies within the player's
  // active half-extents are "Active": rendered, BT at full cadence, vitals
  // at full per-tick rate. Outside, they're "Inactive": no graphics, BT at
  // coarse cadence, vitals scaled by inactiveSlowFactor. Only matters at
  // scale — on a small map every NPC is always Active.
  activeZone: {
    // Floor square half-extent (in tiles) around the player's Position.
    // Used when no renderer viewport hint is available (headless tests, the
    // brief gap during scene swaps). When Game.tsx is mounted, it pushes the
    // canvas dimensions via setViewportHint() and the effective half-extents
    // become max(this floor, viewport/2 + viewportBleedTiles) per axis — the
    // zone may grow above the floor but never shrink below it. Keep the floor
    // generous enough that headless sims behave like the player-facing build.
    activeRadiusTiles: 24,
    // Extra tiles past the visible viewport edge that count as Active.
    // Promotion buffer — NPCs flip to Active slightly before they cross into
    // view, giving the membership tick time to fire before the player can see
    // the popped state. Should be at least a few NPC walking-tiles per
    // membership tick at the highest game speed the renderer is mounted at.
    viewportBleedTiles: 4,
    // Extra tiles past the active half-extent that an Active NPC must exit
    // before being demoted to Inactive. Hysteresis — prevents render/cadence
    // flap for NPCs walking the boundary.
    hysteresisTiles: 2,
    // Game-minutes between active/inactive recomputations. The player's
    // camera can't move enough in one game-minute to matter; checking
    // every frame would be wasted work, especially at hyperspeed.
    membershipTickMin: 1,
    // Inactive simulation slowdown. Per-tick drives (vitals drain, etc.)
    // multiply by this. 0.0 = frozen, 1.0 = full sim. Default 0.25 keeps
    // background NPCs honest (still get hungry off-camera) without making
    // them dominate CPU.
    inactiveSlowFactor: 0.25,
    // Game-minutes between coarse-tick passes for Inactive NPCs. BT,
    // vitals, and relations only run for Inactive NPCs on these
    // boundaries. 5-min cadence × 0.25 slow factor ≈ 1.25× drift per
    // pass, ~4× CPU savings vs per-tick.
    inactiveCoarseTickMin: 5,
  },
}

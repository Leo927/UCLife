// UI audio. Each interaction has its own slot so any single one can be
// replaced without touching neighbors. Currently every clip points at the
// same dummy placeholder; the player tolerates the file 404'ing in dev.
{
  master: {
    volume: 1.0,
    enabled: true,
  },
  // Path resolved relative to the Vite base URL (public/<clip>). Volume is
  // multiplied with master.volume at playback time.
  clips: {
    // ── HUD ─────────────────────────────────────────────────────────
    'ui.hud.debug-toggle':         { clip: 'audio/ui/dummy.mp3', volume: 1.0 },

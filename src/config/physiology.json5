// Phase 4 physiology tunables. Per-template authoring (peak severity,
// duration, scarThreshold, complicationRisk, environmentRisk,
// eligibleBodyParts) lives on individual rows in data/conditions.json5.
// This file holds binding-side constants — the thresholds the daily
// onset rolls read off the character to decide whether to fire.
{
  // Hygiene above this value sustained → cold roll fires per
  // vitalsSaturationDailyRoll. Author chose 70 to keep "showered this
  // week" players safe; pushing it lower turns colds into a tax.
  hygieneSaturation: 70,

  // Per-day probability that the vitals-saturation path picks a
  // template and onsets it (when the character meets the path's
  // trigger). 0.08 ≈ once every two weeks at saturation.
  vitalsSaturationDailyRoll: 0.08,

  // Fatigue above this value sustained → the environment path is
  // eligible for the daily injury roll (sprain, fracture, etc).
  // Walking exhausted on a lunar concourse is the canonical setup.
  fatigueForEnvironmentInjury: 70,

  // Reflex stat at or below this value → labor-work envinjury risk is
  // doubled. Phase 4.1 ships the threshold; the labor-multiplier
  // wiring lands once the work-shift hook exists (currently the daily
  // tick covers the general case).
  reflexForLaborInjury: 40,

  // Medicine skill level required to self-treat a tier-1
  // body-part-scoped injury (sprain / cut / burn) without a pharmacy.
  // First Aid is a planned skill split; until then, the player's
  // medicine level gates this verb.
  selfTreatMinSkillLevel: 30,

  // Phase 4.2 — inactive-zone aggregate SIR. The active zone runs the
  // per-tick contact-radius SIR (src/systems/contagion.ts); for every
  // non-Active living character we instead do one daily aggregate
  // roll: prevalence × aggregateDailyScalar. Tuned so an outbreak at
  // ~10% scene prevalence yields ~1% daily new infections among the
  // unexposed off-camera population — "a flu is going around" without
  // burning the off-screen city to the ground.
  contagionAggregateDailyScalar: 0.10,

  // Phase 4.2 — workplace prevalence log line. When the player begins
  // a work shift, count symptomatic infectious co-workers. At or above
  // this count, emit one zh-CN log line (gated once per game-day so
  // re-entering the same shift doesn't spam).
  workplacePrevalenceThreshold: 2,

  // Phase 4.2 — sneeze/cough emote pulse over symptomatic infectious
  // NPCs (worldspace renderer). All values are in game-time
  // milliseconds. The pulse interval is jittered per entity inside
  // [sneezeEmoteMinMs, sneezeEmoteMaxMs] so a crowded shop doesn't
  // cough in lockstep. Display duration is how long each glyph stays
  // visible per pulse — short enough to read as a beat, long enough
  // for the player to register on a 1× tick.
  sneezeEmoteMinMs: 8000,
  sneezeEmoteMaxMs: 15000,
  sneezeEmoteDisplayMs: 1200,

  // Phase 4.2 — AE clinic gate. Minimum Anaheim reputation required to
  // pass through 安那海姆员工通道. Below this, the AE doctor's kiosk
  // shows the 凭证不足 lockout; at or above, the player gets the
  // diagnose+treat flow with AE perks applied on commit.
  aeClinicMinRep: 20,

  // Phase 4.2 — AE clinic perks layered on top of the tier-2 base when
  // the player commits treatment through the AE doctor. The bonus is
  // additive on PEAK_REDUCTION_BY_TIER[2] (25 base → 35 with default
  // bonus 10) so an AE-treated flu peaks meaningfully lower than a
  // civilian-clinic flu. The scar threshold raise reduces the chance
  // of leaving a chronic stub on resolution.
  aeClinicPeakReductionBonus: 10,
  aeClinicScarThresholdRaise: 10,

  // Phase 4.2 — Anaheim reputation cost per AE clinic visit. Pulled
  // from the player's faction ledger when treatment commits, so the
  // perk has weight against the climb to AE-engineer roles.
  aeClinicRepCost: 1,
}

// Global pacing for NPC replenishment. Per-scene target + arrivalTile live
// on each scene's `replenishment` field in src/data/scenes.json5; this file
// only holds the spawn throttle, which is shared across whichever scene is
// currently replenishing.
{
  // Minimum game-minutes between successive immigrant spawns. 360 = one
  // arrival every 6 game-hours, so a fully-emptied city refills over ~4
  // game-days. Setting this very small turns deaths into instant respawns
  // (more arcade-y); a larger value means the player can witness the
  // population thinning out before reinforcements arrive.
  replenishIntervalMin: 3,
}

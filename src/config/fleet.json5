// Phase 6.2.B fleet configuration. Drives the hangar daily-throughput
// repair formula in src/systems/hangarRepair.ts.
//
// Daily throughput per hangar (from Design/fleet.md):
//   dailyThroughput  =  Σ(worker.workPerformance) × manager.workPerformance × baseRepairPerWorker
//                       (in repair-points per day; 1 point = 1 hull or armor unit)
//   spread            =  dailyThroughput / count(ships not yet fully repaired)
//
// `baseRepairPerWorker` is the per-worker contribution at workPerformance=1.0;
// the manager's workPerformance scales the total. workPerformance is
// resolved by reading the seated NPC's `workPerfMul` stat (defaults to
// 1.0 — Effects from conditions, perks, gear modify it). The floor /
// cap clamp on worker contribution lives below.
//
// `armorBeforeHull` — when repairing a ship, armor is restored before
// hull (matches the Starsector pattern: ablative armor is the outer
// layer to rebuild). With a vacant priority slot, throughput spreads
// evenly across damaged ships at the hangar's POI. With a priority
// slot set, the full pool focuses on that ship.
{
  // Repair points each seated hangar_worker contributes per worked day
  // at workPerformance = 1.0. The state-rental VB surface hangar runs at
  // baseline 4 workers (see jobs.json5 + building-types.json5) → 200
  // points/day before manager scaling. lightFreighter at full damage
  // (hullMax=800 + armorMax=200) needs 5 days at baseline staffing to
  // restore from zero — enough that the manager's repair-priority verb
  // is felt in single-digit game days for the 6.2.B demo.
  baseRepairPerWorker: 50,

  // Manager contribution at workPerformance = 1.0. Multiplicative on the
  // worker sum, capped so a manager-less hangar still produces ~half-rate
  // repair (per Design/fleet.md: hangars run with state-employed baseline
  // staff the player can't always influence).
  managerScaleMin: 0.5,
  managerScaleMax: 1.5,

  // Floor / cap on each worker's workPerformance contribution. Matches
  // the same band research uses so a worker with a bad day can't grind
  // throughput to zero, and a perfect day can't double it.
  perfMin: 0.5,
  perfMax: 1.5,

  // ── Phase 6.2.F — supply + fuel economy ─────────────────────────────
  //
  // AE supply dealer at the industrial compound sells supply / fuel by
  // the unit. Player orders the qty, dealer charges price-per-unit × qty,
  // shipment arrives N days later at the targeted hangar's
  // supplyCurrent / fuelCurrent (capped at the storage max).
  //
  // Order quantum: the smallest order increment shown in the dealer's
  // dialog. Keeps the UI from offering "1 unit of supply" — orders move
  // in chunks the warehouse actually ships. 6.2.F uses one quantum for
  // both supply and fuel; later phases may split by SKU.
  supplyOrderQuantum: 100,

  // Per-unit price the AE dealer charges. Secretary's bulk-order verb
  // applies a faction-office markup multiplier on top (see below).
  supplyPricePerUnit: 5,
  fuelPricePerUnit: 12,

  // In-game days from order placement to delivery at the destination
  // hangar. Per-route overrides land at 6.2.G (transfer-to-other-hangar
  // pipeline); 6.2.F supports one route (VB → VB state hangar).
  supplyDeliveryDays: 2,
  fuelDeliveryDays: 2,

  // Secretary's bulk-order verb at the faction office — late-game scale
  // valve per Design/fleet.md. Markup over the AE dealer price; faster
  // turnaround than the dealer because the secretary leans on faction-
  // tier logistics. Authored separately from the dealer numbers so
  // tuning each surface is independent.
  secretaryBulkOrderMarkup: 1.5,
  secretaryBulkOrderDeliveryDays: 1,

  // Phase 6.2.C1 — delivery lead time (in game days) by hull class.
  // Counts the day-rollover transitions between the order day and the
  // arrival day. lightHull = the AE VB sales rep's product; capital
  // (Pegasus, 6.2.C2) ships from the Granada AE drydock.
  delivery: {
    lightHull: 2,
    capital: 5,
  },

  // Phase 6.2.C1 — AE ship-sales desk tile inside the Von Braun airport
  // (which sits at tile rect 108,10..138,60). The desk is spawned in
  // ecs/spawn.ts:spawnAirport; the rep's special-NPC tileX/tileY MUST
  // equal these so the spawn loop's Workstation.occupant ↔ Job.workstation
  // linkage succeeds.
  shipSalesDeskTileVB: { x: 124, y: 27 },

  // Phase 6.2.C2 — AE ship-sales desk tile inside the Granada drydock
  // concourse. Granada drydock building sits at tile (20,24) with size
  // (20,16) and a north-facing door at offsetTiles=9 (top edge tile
  // x=29). The desk sits on open concourse a few tiles south of the
  // orbital lift (lift at tile (30,4)) and north of the drydock door,
  // so the player walks down from the lift, passes the AE sales desk,
  // and reaches the drydock manager beyond it. The rep's special-NPC
  // tileX/tileY MUST equal these so spawn linkage succeeds.
  shipSalesDeskTileGranada: { x: 30, y: 16 },

  // Phase 6.2.C2 — sales-rep catalog. Maps each AE sales workstation
  // specId to the single hull class that rep sells. Adding a new rep
  // is one new spec + one new row here; the aeShipSales branch is
  // generic over the entry. Each shipClassId must resolve to a row in
  // ship-classes.json5.
  salesRepCatalog: {
    ae_ship_sales_vb:      { shipClassId: 'lunarMilitia' },
    ae_ship_sales_granada: { shipClassId: 'pegasusClass' },
  },

  // Phase 6.2.D — hire-as-captain / hire-as-crew economics. Each hire
  // deducts a one-shot signing fee on accept; daily salary is charged
  // by the day:rollover:settled tick (see boot/fleetCrewSalaryTick.ts).
  // Captains cost more because they emit a Ship-StatSheet officer
  // Effect (currently a small +topSpeed bonus; see captainEffectStat
  // below) and because losing the captain breaks the ship's launch
  // pipeline at 6.2.E+. Numbers are tunable; the smoke pins them via
  // the config import so a tuning change ripples through the assert
  // without code churn.
  hireCaptainSigningFee: 5000,
  hireCrewSigningFee: 500,
  // Per-day per-NPC salary. Pulled from the player's Money on each
  // day:rollover:settled. If the player can't cover the day's bill the
  // tick records the shortfall in the event log; firing happens at
  // the player's discretion (no auto-fire at this slice).
  captainDailySalary: 200,
  crewDailySalary: 30,

  // Captain effect — per-captain Effect on the ship's StatSheet. Source
  // string: `eff:officer:<captainKey>:engineering`. Mods `topSpeed` as
  // a `percentMult` (Effect modType). Bonus scales with the captain's
  // engineering skill level via captainEffectPerLevel — a captain at
  // Lv 30 emits `percentMult = 30 * captainEffectPerLevel` on topSpeed.
  // Engineering is the closest existing skill stub for "ship command";
  // the proper command / tactics / leadership skills land at Phase 6+
  // per the skills.md catalog. Authored at this slice so removing the
  // captain at the fire / reassign verb cleanly removes the Effect.
  captainEffectSkill: 'engineering',
  captainEffectStat: 'topSpeed',
  captainEffectPerLevel: 0.002,

  // Officer auto-man — captain's "man the rest from idle pool" verb on
  // the captain's-office desk. Pulls procedural NPCs without a Job +
  // not already employed as crew + alive and physically present in any
  // city scene. Stops at the configured maximum hires per click OR at
  // `crewRequired` OR at money — whichever comes first.
  manFromIdlePoolMaxPerClick: 20,

  // ── Phase 6.2.E1 — war-room composition surface ────────────────────
  //
  // The war-room plot table renders the player's owned ships as drag-
  // and-drop tokens against an `activeFleetGrid` formation grid. Cell
  // index for a ship in (row, col) is `row * cols + col`; -1 means the
  // ship is in the reserve tray. Grid dimensions stay small so the
  // surface is legible — early fleet scale is two-to-five ships.
  //
  // `flagshipSlot` pins the flagship to a fixed grid cell — the war-
  // room's UX constraint is that the flagship can't be moved out of
  // the active fleet (it's the ship the player is on), so the grid
  // visually anchors it at the center. Computed as
  // `floor(rows/2) * cols + floor(cols/2)`; encoded here so the smoke
  // can assert it without recomputing.
  activeFleetGrid: {
    cols: 4,
    rows: 3,
    flagshipSlot: 6,
  },

  // Aggression doctrine — three-position slider on every active ship.
  // Authored as a list so smoke + UI iterate the same source. The
  // default applied at spawn is the first entry's id ('steady'), with
  // the other two flanking it on the UI. Real combat-AI reads land at
  // 6.2.E2 + 6.2.7 (DP / CP layer); 6.2.E1 ships only the data channel.
  aggressionLevels: [
    { id: 'cautious',  labelZh: '谨慎', aiAggression: 0.3 },
    { id: 'steady',    labelZh: '稳健', aiAggression: 0.5 },
    { id: 'aggressive', labelZh: '激进', aiAggression: 0.8 },
  ],
  aggressionDefault: 'steady',

  // ── Phase 6.2.E2 — auto-launch + cross-POI transit + formation flying ──
  //
  // Formation slot offsets in arena units, indexed by `formationSlot`
  // (0..rows*cols-1). The flagship anchors at slot 6 (offset (0, 0)); the
  // other slots wrap it in the same topology as the war-room plot table
  // grid (4 cols × 3 rows). Used in two places:
  //   - tactical combat: spawn escort CombatShipState at flagshipPos +
  //     offset, station-keep there each tick.
  //   - campaign space (spaceCampaign world): each frame, escorts'
  //     Position rides flagshipPos + offset so the fleet moves as one.
  // The map's first 12 entries cover the default 4×3 grid.
  formationSlotOffsets: {
    '0': { dx: -180, dy: -120 },
    '1': { dx:  -60, dy: -120 },
    '2': { dx:   60, dy: -120 },
    '3': { dx:  180, dy: -120 },
    '4': { dx: -180, dy:    0 },
    '5': { dx:  -60, dy:    0 },
    '6': { dx:    0, dy:    0 },
    '7': { dx:   60, dy:    0 },
    '8': { dx: -180, dy:  120 },
    '9': { dx:  -60, dy:  120 },
    '10': { dx:   60, dy:  120 },
    '11': { dx:  180, dy:  120 },
  },

  // Cross-POI transit days for non-flagship active ships whose home
  // hangar differs from the flagship's POI. The map is symmetric: route
  // key is `${originPoiId}->${destPoiId}`. Missing pairs fall back to
  // `transitDaysDefault`. Tuned so VB↔Granada transit is felt in the
  // 6.2.E2 demo (3 game days — long enough that the escort doesn't
  // teleport to the next engagement, short enough that the player isn't
  // bored). The same surface backs 6.2.G's transfer-to-other-hangar
  // verb (per Design/fleet.md "Transfer-pipeline ownership floats").
  transitDaysDefault: 3,
  transitDays: {
    'vonBraun->granada': 3,
    'granada->vonBraun': 3,
  },
  // Per-transit fee paid from player Money at departure. Authored as a
  // flat charge for now; a per-distance schedule lives at 6.2.G if the
  // map ever grows multi-hop. 0 = free (smoke can drive `cheatMoney`
  // before launch to side-step the gate when needed).
  transitFee: 500,
}

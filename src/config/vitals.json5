// Vitals drains, recoveries, action-modifier multipliers, and HP damage rates.
// Per-game-minute units throughout (the sim ticks once per game-minute).
{
  // Idle drain rates per game-minute. These describe a character standing
  // around doing nothing — actions below scale or replace these.
  // 0.2778 = 100/360 → hunger maxes in ~6 awake hours; thirst in 8h; fatigue
  // in ~48h; hygiene/boredom in ~24h. Tune to make survival harsher or gentler.
  drain: {
    hunger:  0.2778,
    thirst:  0.2083,
    fatigue: 0.0347,
    hygiene: 0.0694,
    boredom: 0.0694,
  },

  // Action overrides. Numeric values replace the base drain entirely (e.g.,
  // eating sets dHunger = -10/min); *Mult scales the base drain.
  actions: {
    eating:   { hunger: -10 },        // 100 hunger cleared in 10 min
    drinking: { thirst: -100 },       // 100 thirst cleared in 1 min (a single sip)
    washing:  { hygiene: -10 },
    reveling: { boredom: -3.3333 },   // -100/30 → bar clears 100 boredom in 30 min
    sleeping: {
      hungerMult: 0.15,               // 15% of base — small but non-zero
      thirstMult: 0.15,
      // Recovery rate at base-mult bed (1.0). Multiplied by bed-tier
      // multiplier (see config/actions.json5 → bedMultipliers).
      fatigue: -0.2083,
      boredom: 0,                     // boredom doesn't tick while asleep
    },
    working: {
      hungerMult:  1.2,
      thirstMult:  1.2,
      fatigueMult: 1.2,
      hygieneMult: 1.2,
      // Working accumulates boredom faster — the daily grind.
      boredomMult: 1.4,
    },
    reading: {
      fatigueMult: 1.2,
    },
  },

  // NPCs accumulate fatigue at this fraction of player-rate so an
  // unsupervised colony doesn't burn itself out.
  npcFatigueMult: 0.5,

  // Passive HP regeneration per game-minute when no needs are critical.
  // ~55h to fully heal from 0 at this rate.
  hpRegenPerMin: 0.03,

  // HP loss per game-minute when each vital is saturated (=100). Stacking is
  // additive. Dehydration is the deadliest by design — these calibrate the
  // "death from neglect" timeline.
  hpDamagePerMin: {
    thirst:  0.025,
    hunger:  0.02,
    fatigue: 0.005,
  },

  // Status-panel flavor-text bands. Boundaries match the player-facing
  // labels in `src/ui/StatusPanel.tsx`. `critical` is the urgency tier —
  // the player should only see it when intervention is required *now*; it
  // gets its own deeper red and a flashing animation so it cannot be
  // mistaken for the merely-severe band below it.
  flavor: {
    // Vital bars (hunger/thirst/fatigue/hygiene/boredom): higher = worse.
    // Pick the first label whose `under` is greater than the value; the
    // tail catches everything ≥ critical.
    vitalBands: [
      { under: 25,  label: '良好' },
      { under: 50,  label: '微感' },
      { under: 75,  label: '明显' },
      { under: 95,  label: '严重' },
      { under: 101, label: '极限', critical: true },
    ],
    // HP bar (inverted): higher = better.
    hpBands: [
      { atLeast: 80, label: '良好' },
      { atLeast: 50, label: '轻伤' },
      { atLeast: 25, label: '重伤' },
      { atLeast: 0,  label: '濒死' },
    ],
    // Distinct deep red for the critical band so 极限 never reads as a
    // saturated 严重.
    criticalColor: '#b91c1c',
  },
}

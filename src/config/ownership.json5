// Phase 5.5 default ownership map. Keyed by building-types.json5 id.
//
//   kind: 'state'                          — civic / state-supported. No payroll
//                                            modeling; the city eats the cost.
//                                            Realtor lists these in the
//                                            state-inventory band.
//   kind: 'faction', factionId: <id>       — owned by a canonical NPC faction.
//                                            Owner.entity resolves to the
//                                            spawned Faction entity at boot.
//   kind: 'private'                        — privately owned by an NPC.
//                                            spawnBuilding seats kind='state'
//                                            as a holding pattern; the post-
//                                            spawn seedPrivateOwners pass
//                                            re-stamps each building with a
//                                            named NPC drawn from the
//                                            founding civilians.
//
// 'character' ownership has no default — the player or a named NPC takes a
// facility through the realtor surface or via inheritance (later).
{
  defaults: {
    // ── Civic / state-supported ───────────────────────────────────────────
    park:            { kind: 'state' },
    airport:         { kind: 'state' },
    transitTerminal: { kind: 'state' },
    clinic:          { kind: 'state' },
    pharmacy:        { kind: 'state' },
    shop:            { kind: 'state' },
    realtor:         { kind: 'state' },
    hrOffice:        { kind: 'state' },
    factionOffice:   { kind: 'state' },
    recruitOffice:   { kind: 'state' },
    researchLab:     { kind: 'state' },
    // Phase 6.2.A — state-rental hangar. stateLocked, no payroll modeling,
    // BT-claimed manager + workers. Player-owned hangars (6.2.A.2 / 6.3)
    // would not be 'state' here; that ownership flips at purchase time.
    hangarSurface:   { kind: 'state' },

    // ── Faction-misc ──────────────────────────────────────────────────────
    aeComplex: { kind: 'faction', factionId: 'anaheim' },

    // ── Private (seeded NPC owners) ───────────────────────────────────────
    bar:       { kind: 'private' },
    factory:   { kind: 'private' },
    apartment: { kind: 'private' },
    luxury:    { kind: 'private' },
    flop:      { kind: 'private' },
    dorm:      { kind: 'private' },
  },
}

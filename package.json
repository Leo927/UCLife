{
  "name": "uclife-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:portrait-cache": "tsx scripts/buildPortraitCache.ts",
    "prebuild": "npm run build:portrait-cache",
    "test:unit": "vitest run",
    "lint:arch": "depcruise --ignore-known --config .dependency-cruiser.cjs src",
    "lint:arch:baseline": "depcruise --output-type baseline --output-to .dependency-cruiser-known-violations.json --config .dependency-cruiser.cjs src",
    "ci:local": "node scripts/ci-local.mjs"
  },
  "dependencies": {
    "idb-keyval": "^6.2.2",
    "json5": "^2.2.3",
    "koota": "^0.4.2",
    "mistreevous": "^4.3.1",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rot-js": "^2.2.1",
    "superjson": "^2.2.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dependency-cruiser": "^17.4.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
